# Caddy reverse proxy with automatic Let's Encrypt TLS.
# DOMAIN and ACME_EMAIL are injected from the environment (see docker-compose.yml).
# Defaults keep `caddy validate` green offline; production overrides them via .env.
{
	email {$ACME_EMAIL:admin@example.com}
}

{$DOMAIN:localhost} {
	encode gzip
	reverse_proxy open-webui:8080
}
