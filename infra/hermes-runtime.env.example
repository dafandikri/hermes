# Desired non-secret Hermes Agent runtime settings.
# Copying is not required; scripts read these defaults unless env overrides are provided.
HERMES_PROVIDER=openai-codex
HERMES_MODEL=openai/gpt-5.5
HERMES_CODEX_GPT55_AUTORAISE=false
HERMES_COMPRESSION_ENABLED=true
RTK_HERMES_MODE=rewrite
RTK_HERMES_TIMEOUT_MS=2000
RTK_HERMES_PREVIEW_MARKER=true
RTK_HERMES_BACKENDS=local
